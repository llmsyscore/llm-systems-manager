# docker compose environment — cp .env.example .env, then fill in the secrets.
# Generate tokens with:  openssl rand -hex 32

# REQUIRED — InfluxDB admin credentials (created on first boot) + API token.
# The token is used by the alarm engine for metric reads/writes and rollup.
LSM_INFLUX_PASSWORD=
LSM_INFLUX_TOKEN=

# STRONGLY RECOMMENDED — bearer token agents must present to push metrics.
# Leaving it unset (REPLACE_ME) leaves the ingest surface open.
LSM_AE_INGEST_TOKEN=

# RECOMMENDED — separate token for the alarm engine's management routes
# (rules/alerts/channels). Blank = they accept the ingest token.
LSM_AE_MANAGEMENT_TOKEN=

# Where the manager (and, via heartbeat, the agents) reach the alarm engine.
# Default works inside the compose network. When native agents on other hosts
# will connect, set this to the docker host's LAN IP so agents can reach it
# AND so the auto-issued AE TLS cert covers that address:
# LSM_ALARM_ENGINE_URL=http://<docker-host-LAN-IP>:8081

# Optional overrides (defaults shown):
# LSM_INFLUX_ORG=llm-systems-manager
# LSM_INFLUX_USERNAME=llmsys
# LSM_INFLUX_RETENTION=30d
# LSM_AE_TLS_ENABLED=true
# LSM_CORS_ORIGINS=http://localhost:5000
# LSM_LOG_LEVEL=INFO
# LSM_IMAGE_TAG=latest
