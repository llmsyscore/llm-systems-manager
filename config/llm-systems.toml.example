# =============================================================================
# llm-systems.toml — single source of truth for manager + alarm engine config
# =============================================================================
#
#   • Real file lives at /opt/llm-systems-manager/config/llm-systems.toml
#     (gitignored, mode 0600 — contains secrets).
#   • Set LLM_SYSTEMS_CONFIG=/some/path/llm-systems.toml to override that
#     location (the systemd units do this).
#   • Missing keys fall back to the defaults in config/unified_config.py — set
#     only the values you want to change.
#   • Agents do NOT read this file. They use their own agent_config.yaml.
#
# To set up a new host:
#   cp config/llm-systems.toml.example /opt/llm-systems-manager/config/llm-systems.toml
#   chmod 600 /opt/llm-systems-manager/config/llm-systems.toml
#   $EDITOR /opt/llm-systems-manager/config/llm-systems.toml
#   sudo systemctl restart llm-systems-alarm-engine llm-systems-manager
#
# Anything marked ★ is a secret and MUST NOT be committed.
# =============================================================================


# ───────────────────────────── MANAGER ────────────────────────────────────
# Flask backend on the primary host. Serves the dashboard, proxies to other
# services, registers agents, runs the in-memory metric ring buffer.
[manager]
host = "0.0.0.0"                                         # listen address
port = 5000                                              # listen port (HTTP)
tls_port = 5443                                          # set to 0 to disable HTTPS

# Fixed worker-thread pool size shared by both servers (HTTP + TLS). Each
# worker is a real OS thread (~8 MB); requests past the ceiling queue ~10s
# then are refused. Floor for a kiosk + several operators is ~32.
http_threads = 64

# Workers reserved for non-stream (control/health/heartbeat) requests. Each
# live SSE stream pins one worker, so concurrent streams are capped at
# http_threads - stream_reserve_threads; over the cap → 503 + retry.
stream_reserve_threads = 24

# Proxied SSE relay reaping: keepalive every stream_keepalive_s detects a
# departed browser fast; stream_max_lifetime_s force-ends half-closed
# streams (the EventSource just reconnects).
stream_keepalive_s = 8
stream_max_lifetime_s = 120

# Lifetime cap for proxied long-running op streams (build/download/bench/
# autotune); raise on slow hosts or large downloads.
stream_op_max_lifetime_s = 3600

# Standalone WebSocket proxy port (browser /ws/alarm → alarm-engine /ws,
# internal-CA cert verified upstream). Lets plain-HTTP dashboards reach the
# wss AE without trusting the internal CA. Serves plain ws; set to 0 when a
# public-CA reverse proxy fronts the AE.
ws_proxy_port = 5444

# Standalone SSE daemon port for /api/llama-state/stream — a held stream
# costs an asyncio task instead of a pinned worker. Browsers fall back to
# the main pool when 0, the daemon is down, or the dashboard is HTTPS
# (the daemon serves plain http).
stream_proxy_port = 5445

# Hard lifetime cap (s) per daemon SSE stream — backstop against half-open
# browsers; the frontend re-mints a token and reconnects.
stream_proxy_lifetime_s = 600

# Dashboard polling cadence: poll_interval while llama-server sleeps and LM
# Studio is idle, fast_poll_interval while either is active.
poll_interval = 60                                       # idle cadence (seconds)
fast_poll_interval = 15                                  # active cadence (seconds)
wait_timeout = 60                                        # llama-server idle threshold (s) before "sleeping"

# Co-located: localhost (auto-advertised to agents at the manager's
# reachable IP). Split install: use the AE's IP, not a hostname — an IP
# needs no per-agent DNS and the AE TLS cert SAN auto-covers it.
alarm_engine_url = "http://localhost:8081"               # where the manager finds the alarm engine

cors_origins = "http://localhost:5000"
log_level = "INFO"                                       # per-service override; falls back to [logging].level

[manager.proxies]
# Browser-facing reverse-proxy targets driving /proxy/<name>/ and /sdcpp/.
# Values per entry:
#   true | "auto"         discover from the agent registry: llm_chat → the
#                         primary llama agent :8080; openclaw / image_gen →
#                         first approved agent advertising that capability
#                         (ports 18789 / IMGGEN_PORT, default 1234). No
#                         advertising agent → the tab stays hidden.
#   false                 disabled — /proxy/<name>/ 404s, tab stays hidden.
#   "http://<host>:<port>" explicit upstream URL.
# Flip to false to keep a tab hidden even when an agent advertises it.
llm_chat  = "auto"
openclaw  = "auto"
image_gen = "auto"

# ── Inference gateway ────────────────────────────────────────────────
# OpenAI-compatible endpoint: POST /api/gateway/v1/chat/completions.
# Routes to a healthy llama agent (pin > ?agent= > pool > default).
[manager.gateway]
enabled = true

# Bearer keys for external OpenAI-SDK clients (accepted only on
# /api/gateway/*). Empty = dashboard-session access only.
api_keys = []

# Upstream read timeout per completion request (generation can take minutes).
read_timeout_s = 600.0

[manager.history]
# In-memory ring buffer behind /api/history; sets how far back the landing
# charts pre-populate. RAM cost grows roughly linearly with window_minutes.
window_minutes = 60                                      # ring depth (minutes)
refresh_interval_s = 15.0                                # background refresher cadence
fetch_limit = 1800                                       # alarm-engine fetch cap per series per refresh

[manager.uploads]
max_content_length = 104857600                           # bytes; default 100 MiB

[manager.timeouts]
generic_http = 30.0                                      # outbound HTTP default (s)

[manager.agents]
stale_after_s = 150                                      # heartbeats missed → "stale"
down_after_s = 600                                       # heartbeats missed → "down"
liveness_watch_interval_s = 65                           # how often the watcher loop runs

[manager.security]
# CIDR ranges allowed to call admin-only endpoints (rule/channel CRUD, etc.).
admin_cidrs = ["127.0.0.1", "::1", "192.168.1.0/24", "192.168.2.0/24"]

tls_rotation_warn_days = 30                              # warn when certs expire within N days
stream_token_ttl_s = 300                                 # short-lived SSE/EventSource HMAC tokens

# CSP applied to proxied HTML (llama Chat UI, AE SPA, OpenClaw, image-gen).
# 'unsafe-inline' is required (injected shims); cdn.jsdelivr.net serves the
# SPAs' Chart.js/date-fns. Set to "" to strip CSP if a proxied UI breaks.
proxy_html_csp = "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; img-src 'self' data: blob:; font-src 'self' data: https://cdn.jsdelivr.net; connect-src 'self' ws: wss:; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; object-src 'none'"

[manager.auth]
# Dashboard login (single shared admin). Browser sessions are gated; agent
# (bearer-token) calls never are.
#   mode = "required"      every browser must log in (default)
#        | "disabled"      no login (trusted-LAN behaviour)
#        | "trusted_cidr"  login required except from [manager.security].admin_cidrs
#        | "auto"          UI-managed: data/manager_auth.json holds the live
#                          mode; Admin-tab changes apply instantly
# Any non-"auto" value wins over the Admin tab (applies on restart). The
# Admin dropdown omits "auto" — switching into/out of it is a TOML edit.
mode = "auto"

# Seed username, matching the built-in fallback credential used while
# password_hash is blank (llmadmin/llmadmin).
username = "llmadmin"

# ★ Secret. scrypt hash "scrypt$<salt_b64>$<dk_b64>". Leave blank to use the
# dashboard's first-run setup page (or set the login from the Admin tab).
password_hash = ""

session_lifetime_days = 1

# Role for sessions that skip login (trusted_cidr from an admin CIDR, or
# disabled mode): "admin" (default) or "operator".
bypass_role = "admin"

# Failed-login lockout: lock a username OR source IP after this many
# failures within lockout_window_s, for lockout_duration_s.
lockout_threshold = 5
lockout_window_s = 900
lockout_duration_s = 900

[manager.branding]
# Accent palette for the login page + dashboard logo.
# One of: "teal" | "indigo" | "forest" | "steel" (unknown → indigo).
palette = "indigo"

[manager.backup]
# Scheduled automatic backups: export archive (same format as Admin →
# Backup & Restore) written to data/backups/, pruned past keep_last.
# Archives are UNENCRYPTED unless passphrase is set.
enabled = true
interval_hours = 24.0                                    # 0 disables the scheduler
keep_last = 7                                            # archives retained after pruning

# ★ Secret (when set). AES-256-GCM passphrase (12+ chars) for scheduled
# archives; also required to import them. Blank = plaintext archives.
passphrase = ""

# Optional second directory (e.g. a mounted NAS path) each archive is copied to.
mirror_dir = ""


# ────────────────────────────── OPENCLAW ──────────────────────────────────
# Cost analytics for OpenClaw agents (Dashboard → OpenClaw sub-tab).
[openclaw]
# Monthly budget ceiling (USD) for the fleet's projected spend. > 0 pushes
# budget metrics to the alarm engine and seeds "OpenClaw budget" rules at
# the AE's next start; 0 disables. Rules seed ONCE — edit later changes in
# the alarms UI.
monthly_budget_usd = 0.0
budget_warning_pct = 80.0                                # warn at this % of budget

# Also alert when a session's cost is anomalous (>2x rolling average).
notify_cost_anomalies = false

metrics_push_interval_s = 300.0                          # budget metric push cadence


# ───────────────────────────── ALARM ENGINE ───────────────────────────────
# FastAPI service on port 8081. Owns alert rule evaluation, notification
# dispatch, InfluxDB writes, and the alarms UI.
[alarm_engine]
host = "0.0.0.0"
port = 8081
evaluation_interval = 15                                 # rule eval cadence (s)
keepalive_interval = 30                                  # WebSocket keepalive (s)
manager_url = "http://localhost:5000"                    # back-channel to the manager
cors_origins = "http://localhost:5000"
log_level = "INFO"                                       # per-service override

# ★ Secret. Bearer token required on the ingest surface (agent metric POSTs
# + OTLP /v1/* + /api/alarm/ingest); the installer generates one at install
# time. Blank or "REPLACE_ME" leaves ingest OPEN (back-compat). The manager
# hands it to agents on heartbeat ack — rotation propagates within ≤60 s.
ingest_token = "REPLACE_ME"

# ★ Secret. Bearer token for the management routes (rules/alerts/
# notifications). Blank or "REPLACE_ME" = they accept ingest_token.
management_token = ""

# Serve the AE over HTTPS (encrypts the metric-push path, which carries
# ingest_token). Co-located installs get data/ae-tls.{crt,key} pre-issued
# from the manager's internal CA; on a split install copy those two files
# from the manager host into the AE host's llm-systems-alarm-engine/data/.
# Enabled-but-cert-missing → error in log + Admin tab, falls back to HTTP.
tls_enabled = true

# Paths relative to the alarm-engine package root; auto-issued at install +
# manager startup.
tls_cert_file = "data/ae-tls.crt"
tls_key_file  = "data/ae-tls.key"

[alarm_engine.timeouts]
influxdb_ping         = 2.0                              # InfluxDB self-monitor probe
ws_send               = 5.0                              # per-client websocket send (s)

[alarm_engine.intervals]
influxdb_monitor_s         = 30                          # how often the influx self-monitor runs
websocket_heartbeat_log_s  = 60                          # WS heartbeat log cadence
otlp_heartbeat_s           = 60                          # OTLP receiver heartbeat log cadence

[alarm_engine.caches]
size                          = 100000                   # max entries in the in-memory cache
ttl_s                         = 900                      # default cache entry TTL
rule_repo_ttl_s               = 300                      # rule list memoization (5 min)
alert_repo_ttl_s              = 300                      # active-alert list memoization (5 min)
metric_catalog_warmup_days    = 7                        # boot scan depth for the metric dropdown
websocket_queue_size          = 500                      # WS out-queue depth

# ── Alert correlation / incident grouping ────────────────────────────
[alarm_engine.correlation]
enabled = true             # false → every alert self-roots
window_seconds = 60.0      # same-host time-window join
notify_per_incident = true # suppress channel dispatch for joiner alerts (toasts unaffected)

[alarm_engine.retention]
alert_history_days = 90    # purge alert_history rows older than this; 0 = keep forever
purge_interval_s = 3600.0  # how often the purge task runs

[alarm_engine.api_limits]
# Hard caps for FastAPI query parameters — raise for longer/larger
# requests, lower to guard against accidental DOS via deep history.
recent_alerts_limit_max      = 5000                      # /api/alarm/alerts/recent  limit cap
history_since_minutes_max    = 43200                     # /api/alarm/metrics/{...}  since_minutes cap (30 d)
history_limit_max            = 100000                    # /api/alarm/metrics/{...}  limit cap
summary_window_minutes_max   = 10080                     # /api/alarm/metrics/{...}/summary window cap (7 d)
export_since_minutes_max     = 43200                     # /api/alarm/metrics/export since_minutes cap (30 d)
max_request_body_bytes       = 104857600                 # HTTP body cap, all AE routes (100 MiB; 0 = uncapped)

# Server-side downsampling for long history queries.
[alarm_engine.history.downsampling]
rollup_enabled    = true                                 # set false to fall back to raw scans
rollup_measurement = "metrics_1m"                        # measurement name in metrics_rollup_bucket
rollup_every      = "1m"                                 # rollup bin size (Flux task `every:`)

# First tier whose max_window_s >= the requested window wins; larger
# windows fall through to the last tier.
[[alarm_engine.history.downsampling.tiers]]
max_window_s = 21600                                     # 6 h
every = "1m"
[[alarm_engine.history.downsampling.tiers]]
max_window_s = 86400                                     # 24 h
every = "1m"
[[alarm_engine.history.downsampling.tiers]]
max_window_s = 604800                                    # 7 d
every = "5m"
[[alarm_engine.history.downsampling.tiers]]
max_window_s = 2592000                                   # 30 d
every = "30m"

[alarm_engine.default_rules]
# Seed thresholds for the default alarm rules, applied ONLY at first boot
# when no rules exist. After that, edit rules via the UI.
cpu_usage_critical = 95.0                                # %
cpu_temp_critical  = 80.0                                # °C
gpu_temp_critical  = 85.0                                # °C
gpu_vram_critical  = 95.0                                # %
ram_usage_critical = 90.0                                # %


# ───────────────────────────── INFLUXDB ───────────────────────────────────
# Metrics + their rollup only — rules, channels, deliveries, and alert
# history live in SQLite under llm-systems-alarm-engine/data/.
[influxdb]
host = "localhost"
port = 8086
org  = "llm-systems-manager"
metrics_bucket        = "alarm_engine_metrics"           # raw points, short retention (e.g. 7d)
metrics_rollup_bucket = "alarm_engine_metrics_rollup"    # 1-min rollup, long retention (e.g. 90d)

[influxdb.tokens]
# ★ Secret. Per-bucket scoped tokens; rotate by editing here + restart.
# Generate:
#   influx auth create --org llm-systems-manager --read-bucket <bucket> --write-bucket <bucket>
metrics        = "REPLACE_ME"

# Read+write token for the rollup bucket. Blank disables the rollup split —
# reads fall back to raw scans.
metrics_rollup = "REPLACE_ME"

# Optional operator token used ONLY at startup to create the rollup Flux
# task (bucket-scoped tokens can't create tasks). Blank skips rollup
# creation. Generate:
#   influx auth create --org llm-systems-manager --all-access
admin    = ""


# ───────────────────────────── NOTIFICATIONS ──────────────────────────────
[notifications.smtp]
# ★ Secret. App-specific password for iCloud/Gmail/etc.
server   = "smtp.mail.example.com"
port     = 587
user     = "you@example.com"
password = "app-specific-password-here"

[notifications.twilio]
# ★ Secret (when used). Leave blank to disable SMS.
account_sid  = ""
auth_token   = ""
from_number  = ""

[notifications.discord]
# ★ Secret (when used). Leave blank to disable Discord.
webhook_url = ""

[notifications.timeouts]
http = 10.0                                              # webhook + Discord (s)
smtp = 15.0                                              # email (s)


# ───────────────────────────── PATHS ──────────────────────────────────────
[paths]
log_dir         = "/var/log/llm-systems-manager"         # manager + alarm engine log files
log_max_bytes   = 52428800                               # 50 MiB before rotation
log_backup_count = 5                                     # rotated copies retained


# ───────────────────────────── LOGGING ────────────────────────────────────
[logging]
# Default level for both services; per-service overrides live in
# [manager].log_level and [alarm_engine].log_level.
level   = "INFO"                                         # DEBUG | INFO | WARNING | ERROR | CRITICAL
format  = "%(asctime)s [%(levelname)s] %(name)s:%(funcName)s() - %(message)s"
datefmt = "%Y-%m-%d %H:%M:%S"
