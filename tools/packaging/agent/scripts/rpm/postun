# rpm %postun body — concatenated after common.sh by build-agent-package.sh.
# $1 = 0 means full erase; rpm has no purge tier, so config/data are kept.
if [ "${1:-0}" -eq 0 ]; then
  llmsys_agent_remove_generated
  if llmsys_systemd_ready; then systemctl daemon-reload; fi
  if [ -e "$LLMSYS_AGENT_CFG" ] || [ -d "$LLMSYS_AGENT_DIR/data" ]; then
    echo "llm-systems-agent: config/data kept at $LLMSYS_AGENT_DIR (remove manually for a full purge)"
  fi
fi

exit 0
