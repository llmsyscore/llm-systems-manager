# Managed by llm-systems-agent installer. Do not edit by hand.
# Drop as /etc/sudoers.d/llm-systems-agent (mode 0440).
# On ANY change here, bump SVCCONFIG_WRAPPER_VERSION in llm-svcconfig-apply.sh.tmpl
# so already-migrated agents are prompted to re-run a root install.sh --update.
# Allows the agent (running as ${AGENT_USER}) to run only the systemctl
# commands needed for llama-server lifecycle and the perf controller's
# CPU governor / fan profile units.

Cmnd_Alias LSA_LLAMA = /usr/bin/systemctl start ${LLAMA_UNIT}, \
                       /usr/bin/systemctl stop ${LLAMA_UNIT}, \
                       /usr/bin/systemctl restart ${LLAMA_UNIT}, \
                       /usr/bin/systemctl daemon-reload, \
                       /usr/local/llama-server/build-llama-cpp.sh "", \
                       /usr/local/sbin/llm-svcconfig-apply ""

Cmnd_Alias LSA_PERF  = /usr/bin/systemctl reload-or-restart powersave, \
                       /usr/bin/systemctl reload-or-restart performance, \
                       /usr/bin/liquidctl status --match Kraken, \
                       /usr/bin/liquidctl status --match HX1000i, \
                       /usr/bin/liquidctl status --match "Smart Device"

${AGENT_USER} ALL=(root) NOPASSWD: LSA_LLAMA, LSA_PERF
