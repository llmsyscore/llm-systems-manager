# LLM Systems Agent - example configuration
# Copy to one of:
#   /etc/llm-systems-agent/agent_config.yaml
#   /opt/llm-systems-agent/agent_config.yaml
#   ./agent_config.yaml (if running from a custom CWD)
#
# Any field can also be overridden by environment variable LSA_<NAME>.
# Booleans accept: true/false, 1/0, yes/no, on/off.
# Lists in env vars use "|" as separator (e.g. LSA_PERF_SLEEP_MARKERS="m1|m2").

# -- Agent identity ---------------------------------------------------------
AGENT_OS:          linux             # "linux" or "macos"
AGENT_ROLE:        auto              # auto | llama_host | lms_host | mixed | system_only
AGENT_HOSTNAME:    ""                # blank => socket.gethostname() at runtime
AGENT_BIND_HOST:   "0.0.0.0"
AGENT_BIND_PORT:   8082
AGENT_DESCRIPTION: ""                # human-friendly label shown in the admin tab
# Run-as user + install directory. The installer fills these in to match
# the values selected at deploy time; leave blank if you want the agent
# to detect them at runtime (current login user; install dir derived from
# the running script's location).
AGENT_USER:        ""
AGENT_INSTALL_DIR: ""
# -- TLS (manager-issued certs) ---------------------------------------------
# The manager's internal CA signs a leaf cert + key on agent approval and
# pushes them via POST /api/agents/<id>/cert-bundle. With all three files
# present and readable, the agent serves HTTPS on AGENT_BIND_PORT and HTTP
# is rejected. Leave the defaults unless you've moved the data/ dir.
# TLS_CERT_FILE: "data/tls-cert.pem"
# TLS_KEY_FILE:  "data/tls-key.pem"
# TLS_CA_FILE:   "data/tls-ca.pem"

# -- Self-update source tree ------------------------------------------------
# Where the agent looks for the upstream checkout when /agent/self-update
# fires. Blank => {AGENT_INSTALL_DIR}/src (what the installer sets up).
# AGENT_REPO_DIR: ""

# -- Manager + alarm engine -------------------------------------------------
# Set during install (or pass --manager-url to the installer). The alarm
# engine is assumed to be on the same host as the manager, port 8081.
MANAGER_URL:      ""
ALARM_ENGINE_URL: ""
# Note: when the alarm engine enforces an ingest token ([alarm_engine].ingest_token
# in the manager's config), the agent receives that token automatically on its
# heartbeat ack and attaches it to metric pushes - there is NO ingest-token key
# to set here. Just keep the agent approved and heartbeating.
#
# TLS auto-upgrade - also no config change needed:
#   * If the manager sets [manager].tls_port (default 5443) it advertises a
#     `manager_https_url` in the heartbeat ack. Once the agent holds the CA
#     bundle (delivered on first approval), it probes https://manager:5443/health
#     against the CA and, on success, switches MANAGER_URL from http to https
#     one-shot per process. A failed probe leaves MANAGER_URL on http.
#   * If [alarm_engine].tls_enabled, the manager advertises an https alarm-engine
#     URL too. The agent's metric push verifies the AE's internal-CA-signed cert
#     and switches its push to https - same probe-before-switch safety.

# -- LM Studio (set LMS_ENABLED: true on hosts running LM Studio) ----------
LMS_ENABLED: false
# LMS_CMD:     ""                              # blank => detected at runtime (which lms / ~/.lmstudio/bin/lms)
# LMS_API_URL: "http://localhost:1235"

# -- llama.cpp (set LLAMA_ENABLED: true on hosts running llama-server) -----
# All paths are commented out by default so the agent's built-in defaults
# apply. The installer fills in actual values during auto-detect / prompts;
# don't hard-code anything site-specific here.
LLAMA_ENABLED: false
# LLAMA_BIN:           ""    # llama-server binary, e.g. /usr/local/llama-server/llama-server
# LLAMA_CONFIG_INI:    ""    # llama-server config.ini, e.g. /usr/local/llama-server/config.ini
# LLAMA_LOG_FILE:      ""    # llama-server log file, e.g. /usr/local/llama-server/llama-server.log
# LLAMA_STATE_FILE:    "/tmp/llama-server-last-state"
# LLAMA_SYSTEMD_UNIT:  "llama_server.service"
# LLAMA_API_URL:       "http://localhost:8080"
# LLAMA_BUILD_METHOD:  ""    # custom_script|source|release_binary|conda|homebrew (blank => custom_script)
# LLAMA_BUILD_DIR:     ""    # managed install root for source/release_binary; blank => ~/.local/share/llama.cpp
# LLAMA_BUILD_OPTS:          # per-method knobs (YAML only — not settable via LSA_* env)
#   git_ref: master          #   source: branch/tag/commit
#   backend: cpu             #   source: cpu|cuda|vulkan|metal|rocm
#   version: latest          #   release_binary: 'latest' or a release tag
#   script_path: /usr/local/llama-server/build-llama-cpp.sh   # custom_script
#   install_in_place: false  #   source/release_binary: swap new binaries+libs
#                            #   onto dirname(LLAMA_BIN) (agent-writable only)
#   backup_retain: 2         #   in-place upgrade: how many .upgrade.bak.* to keep

# -- Performance controller (replaces the bash daemon) ---------------------
# Requires LLAMA_ENABLED=true and a Linux host. The agent tails
# LLAMA_LOG_FILE, writes LLAMA_STATE_FILE, and runs:
#     sudo systemctl reload-or-restart {PERF_TARGET_AWAKE | PERF_TARGET_SLEEP}
# on transitions. The targets must be valid systemd targets/units (matching
# the existing performance/powersave units already on the host).
PERF_CONTROLLER_ENABLED: false
PERF_TARGET_AWAKE:  "performance"
PERF_TARGET_SLEEP:  "powersave"
# PERF_SLEEP_MARKERS:
#   - "server is entering sleeping state"
#   - "cmd_child_to_router:sleep"
# PERF_WAKE_MARKERS:
#   - "server is exiting sleeping state"
#   - "main: loading model"
#   - "model loaded"
#   - "load_model: loading model"

# -- OpenClaw (set OPENCLAW_ENABLED: true on hosts running OpenClaw) ------
OPENCLAW_ENABLED:    false
# OPENCLAW_AGENTS_DIR: ""              # blank => ~/.openclaw/agents

# -- Image generation (stable-diffusion.cpp sd-server) --------------------
# Setting this true advertises the "image_gen" capability to the manager.
# The manager's /proxy/imggen/ "auto" mode picks the first approved agent
# with this capability and proxies the dashboard tab to IMGGEN_PORT on
# that host. No URL goes here - the agent's registered IP is the source.
# Override IMGGEN_PORT when sd-server is bound to a non-default port; the
# agent advertises the value at registration so no manager-side TOML edit
# is required.
IMGGEN_ENABLED:      false
# IMGGEN_PORT:         1234

# -- HuggingFace CLI  ---------------------------------------------
# HF_CLI_PATH: ""        # blank => shutil.which("hf")

# -- HTTP worker pool / SSE stream cap --------------------------------------
# Uvicorn runs sync handlers + sync-generator SSE streams in the anyio worker
# pool. WORKER_THREADS raises it off the stock 40; concurrent SSE streams are
# capped at WORKER_THREADS - STREAM_RESERVE_THREADS so held streams can't
# starve sync control requests (terminal, status). Over the cap => HTTP 503.
WORKER_THREADS:         64
STREAM_RESERVE_THREADS: 24

# -- Collection / forwarding ------------------------------------------------
POLL_INTERVAL_S:      5
HEARTBEAT_INTERVAL_S: 60
COLLECTION_ENABLED:   true     # admin can toggle at runtime via /agent/collection

# -- BufferedMetricClient - alarm engine push tuning ------------------------
# The collector samples every POLL_INTERVAL_S, but the agent does NOT POST
# every sample. Samples are queued and flushed as a batch every
# METRIC_FLUSH_INTERVAL_S.
METRIC_FLUSH_INTERVAL_S:   30
METRIC_MAX_MEMORY_SAMPLES: 400   # in-memory ring size before disk spill
METRIC_BATCH_LIMIT:        1000  # max samples per POST (caps backlog drains)
METRIC_HTTP_TIMEOUT_S:     10

# Agent pushes host metrics to the manager on every collector tick. Gated
# by this knob plus the manager's primary-llama election (only the primary
# llama agent's push is kept) - off means the agent stays dormant.
PUSH_HOST_METRICS_ENABLED: true

# -- Manager / alarm-engine / Influx self-monitor probes --------------------
# When MONITOR_MANAGER_ENABLED, a background thread times the manager's
# HTTP endpoints (MANAGER_URL is reused). When MONITOR_ALARM_ENGINE_ENABLED,
# it also times the alarm engine (ALARM_ENGINE_URL is reused) and probes
# InfluxDB directly (write + 5m/24h Flux reads + disk usage). Results land
# in the alarm engine catalog under source=`manager_self_monitor`, available
# for dashboard graphing and rule-based alerting.
#
# Both default false. The installer sets them automatically when it detects
# the corresponding systemd unit (llm-systems-manager.service /
# llm-systems-alarm-engine.service) on the host being installed. Flip them
# on independently here when the manager and alarm engine live on different
# hosts and you want this agent to probe one but not the other.
MONITOR_MANAGER_ENABLED:      false
MONITOR_ALARM_ENGINE_ENABLED: false
META_PERF_INTERVAL_S:         60   # seconds between probe passes
META_PERF_TIMEOUT_S:          5    # per-probe HTTP/InfluxDB timeout

# InfluxDB on-disk-bytes probe - `du -sb /var/lib/influxdb`. Lands in
# the alarm engine catalog as source=`influxdb`, metric_name=`bytes_on_disk`,
# tagged with this host. Auto-enabled by the installer when influxdb.service
# is active on this host. On split installs where InfluxDB lives on its
# own machine, this is the only thing that populates the disk-bytes
# series - the AE has no /var/lib/influxdb to scan.
#
# Reads the influxdb data dir via `du -sb`. Plain `du` works if the dir is
# world-readable; falls back to `sudo -n du` (the installer drops a
# /etc/sudoers.d/llmsys-du-influxdb rule with the right NOPASSWD entry).
# Cached for INFLUXDB_DISK_PROBE_INTERVAL_S seconds - walking thousands
# of TSM files on every 5-second collector tick would be wasteful.
MONITOR_INFLUXDB_DISK_ENABLED:    false
# Blank - auto-detect /var/lib/influxdb then /var/lib/influxdb2. Set
# explicitly only when InfluxDB's data is on a non-standard path.
INFLUXDB_DATA_PATH:               ""
INFLUXDB_DISK_PROBE_INTERVAL_S:   300

# -- Process / service watchlist --------------------------------------------
# Each tick the agent reports {running: 0|1, pid, rss_mb, uptime_s} for
# each entry. Emitted under `source=processes`, `metric_name=<name>_running`
# (etc.) so alarm rules can fire on "<name>_running == 0". Leave the list
# blank to accept the per-OS defaults baked into the agent (llama-server,
# influxdb, manager, alarm-engine on Linux; LM Studio + sd-server on macOS).
PROCESS_WATCH_ENABLED: true
# PROCESS_WATCHLIST:
#   - name: llama-server
#     match: systemd
#     unit: llama_server.service
#   - name: influxdb
#     match: systemd
#     unit: influxdb.service
#   - name: lm-studio
#     match: process
#     pattern: "LM Studio"

# -- Host hardware collection toggles ---------------------------------------
# All default true; each helper degrades cleanly if its source isn't
# present (AMD GPU on a Mac, lm-sensors not installed, no NUT-attached UPS,
# etc.). Set any to false to skip the subprocess/sysfs work entirely.
COLLECT_GPU_ENABLED:       true
COLLECT_SENSORS_ENABLED:   true
COLLECT_LIQUIDCTL_ENABLED: true
COLLECT_UPS_ENABLED:       true
COLLECT_ISCSI_ENABLED:     true
# LIQUIDCTL_BIN: ""   # optional override; default = `liquidctl` on PATH

# -- macOS powermetrics (Apple Silicon thermal / power / GPU residency) ----
# macOS-only. Requires a sudoers.d entry so the agent can spawn
# powermetrics without a password - for example:
#   echo '<agent-user> ALL=(root) NOPASSWD: /usr/bin/powermetrics' \
#     | sudo tee /etc/sudoers.d/llmsys-powermetrics
# The agent emits the sampler block under `source=mac_power` so rules can
# alert on thermal_pressure_n or cpu_die_temp_c. The installer flips this
# to true automatically on macOS hosts and leaves it false on Linux.
COLLECT_POWERMETRICS_ENABLED: false
# POWERMETRICS_INTERVAL_MS:     5000

# -- Log-file watcher - alarm engine ----------------------------------------
# Periodically tails the listed files looking for regex matches. Each match
# POSTs to {ALARM_ENGINE_URL}/api/alarm/ingest as a generic alert, which is
# then routed through the same alert_manager as internal rules (deduplicated,
# delivered to whatever notification channels are configured).
#
# Per-rule offsets are persisted to data/log-watch-state.json so the agent
# resumes after a restart instead of re-firing old matches. The very first
# observation of a new rule jumps to EOF - historical lines never alert.
# File rotation/truncation is detected via inode change and starts from 0.
#
# Per-rule fields (only `name`, `path`, `pattern` are required):
#   name          alert name + dedup key
#   path          absolute path to the log file
#   pattern       Python regex (re.search; prefix "(?i)" for case-insensitive)
#   severity      "info" | "warning" | "critical"      (default: warning)
#   cooldown_s    seconds between fires for this rule  (default: 60)
#   max_per_tick  cap on matches forwarded per tick    (default: 5)
#   message       template string - "{line}", "{path}", "{name}" substituted
#   source        alert source label                   (default: "log-watch")
#   metric        alert metric label                   (default: log filename)
#   enabled       set false to retain the entry but skip it temporarily
#
# To enable: flip LOG_WATCH_ENABLED to true, then uncomment LOG_WATCH_RULES
# AND every line under it (drop the leading "# " from each line). Indent is
# significant - keep the two-space indent before the leading "-" on each
# rule, and the four-space indent on each rule field.
LOG_WATCH_ENABLED: false
LOG_WATCH_INTERVAL_S: 10
LOG_WATCH_MAX_BYTES_PER_TICK: 1048576
# LOG_WATCH_RULES:
#   - name: llama-oom
#     path: /usr/local/llama-server/llama-server.log
#     pattern: "(?i)cuda out of memory|ggml_cuda.*out of memory"
#     severity: critical
#     cooldown_s: 300
#   - name: llama-error
#     path: /usr/local/llama-server/llama-server.log
#     pattern: "(?i)\\b(error|fatal)\\b"
#     severity: warning
#     cooldown_s: 120
#     max_per_tick: 3
#     message: "{name} on {path}: {line}"
#   - name: syslog-oom
#     path: /var/log/syslog
#     pattern: "(?i)out of memory|oom-killer"
#     severity: critical
#     cooldown_s: 600
#     enabled: false

# -- Logging / token storage ------------------------------------------------
# LOG_FILE:    ""        # blank => /var/log/llm-systems-manager/llm-systems-agent.log on Linux,
#                        #          ~/Library/Logs/llm-systems-agent.log on macOS
# TOKEN_FILE:  ""        # blank => {AGENT_INSTALL_DIR}/data/token (mode 0600)
