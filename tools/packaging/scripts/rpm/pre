# rpm %pre body — concatenated after common.sh by build-packages.sh.
# EL can't express a "python3 >= 3.10" Requires, so gate here before
# any files land (stock EL9 python3 is 3.9).
if ! llmsys_pick_python >/dev/null; then
  echo "llm-systems-manager: no Python >= 3.10 found — install one first (e.g. 'dnf install python3.11 python3.11-pip')." >&2
  exit 1
fi

# $1 = 1 fresh install, >= 2 upgrade.
if [ "${1:-1}" -eq 1 ]; then
  llmsys_guard_fresh_install || exit 2
elif hits="$(llmsys_foreign_state)"; then
  echo "llm-systems-manager: WARNING — non-package install state present:$hits (#416)" >&2
fi

exit 0
